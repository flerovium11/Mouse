{
  "manifest_version": 3,
  "name": "Mouse",
  "version": "1.0",

  "description": "Cursor for browser",

  "web_accessible_resources": [
    {
      "resources": ["*.mjs", "*.wasm"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["mouse.js"]
    }
  ]
}
