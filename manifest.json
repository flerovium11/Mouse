{
  "manifest_version": 3,
  "name": "Mouse",
  "version": "0.1.0",
  "description": "AI-powered smart autocomplete for any browser text field",

  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Mouse",
    "default_icon": {
      "128": "images/icon.png"
    }
  },

  "icons": {
    "128": "images/icon.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": ["storage", "tabs", "activeTab"],

  "web_accessible_resources": [
    {
      "resources": ["images/*"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["dist/docs-frame.js"],
      "matches": ["https://docs.google.com/*"]
    }
  ]
}
