{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": ["ES2020", "DOM"],
    "types": ["chrome"],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    },
    "noEmit": true
  },
  "include": ["src/**/*", "vite.config.ts"]
}
