{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["chrome", "vite/client"],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    },
    "noEmit": true
  },
  "include": ["src/**/*", "vite.config.ts"]
}
